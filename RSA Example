import java.math.BigInteger;
import java.util.Scanner;

public class ManualRSAUserInput {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Step 1: Take p and q from user
        System.out.print("Enter prime number p: ");
        BigInteger p = sc.nextBigInteger();

        System.out.print("Enter prime number q: ");
        BigInteger q = sc.nextBigInteger();

        // Step 2: Compute n = p * q
        BigInteger n = p.multiply(q);

        // Step 3: Compute phi(n) = (p-1)(q-1)
        BigInteger phi = (p.subtract(BigInteger.ONE))
                .multiply(q.subtract(BigInteger.ONE));

        // Step 4: Choose e (1 < e < phi and gcd(e,phi)=1)
        BigInteger e = new BigInteger("2");

        while (e.compareTo(phi) < 0) {
            if (e.gcd(phi).equals(BigInteger.ONE)) {
                break;
            }
            e = e.add(BigInteger.ONE);
        }

        // Step 5: Compute d = e^-1 mod phi
        BigInteger d = e.modInverse(phi);

        System.out.println("\nPublic Key (e, n): (" + e + ", " + n + ")");
        System.out.println("Private Key (d, n): (" + d + ", " + n + ")");

        // Step 6: Take message
        System.out.print("\nEnter numeric message (less than " + n + "): ");
        BigInteger message = sc.nextBigInteger();

        if (message.compareTo(n) >= 0) {
            System.out.println("Message must be less than n.");
            return;
        }

        // Step 7: Encryption
        BigInteger cipherText = message.modPow(e, n);
        System.out.println("\nEncrypted Message: " + cipherText);

        // Step 8: Decryption
        BigInteger decryptedMessage = cipherText.modPow(d, n);
        System.out.println("Decrypted Message: " + decryptedMessage);

        sc.close();
    }
}





