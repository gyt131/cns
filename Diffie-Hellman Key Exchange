<!DOCTYPE html>
<html>
<head>
<title>Diffie-Hellman Key Exchange</title>
<script>
function calculateKey() {
    // Public values
    var p = parseInt(document.getElementById("p").value);
    var g = parseInt(document.getElementById("g").value);

    // Alice private key (entered by user)
    var a = parseInt(document.getElementById("alicePrivate").value);

    // Bob private key (generated by JS)
    var b = Math.floor(Math.random() * 10) + 1;

    // Alice public key
    var A = Math.pow(g, a) % p;

    // Bob public key
    var B = Math.pow(g, b) % p;

    // Shared keys
    var aliceKey = Math.pow(B, a) % p;
    var bobKey = Math.pow(A, b) % p;

    document.getElementById("bobPrivate").innerHTML = b;
    document.getElementById("alicePublic").innerHTML = A;
    document.getElementById("bobPublic").innerHTML = B;
    document.getElementById("aliceSecret").innerHTML = aliceKey;
    document.getElementById("bobSecret").innerHTML = bobKey;

}

</script>
</head>
<body bgcolor= "pink">
<h2>Diffie-Hellman Key Exchange Simulation</h2>
<p>Enter Public Prime Number (p):</p>
<input type="number" id="p">
<p>Enter Primitive Root (g):</p>
<input type="number" id="g">
<p>Enter Alice Private Key:</p>
<input type="number" id="alicePrivate">
<br><br>
<button onclick="calculateKey()">Generate Keys</button>
<h3>Results</h3>
<p>Bob Private Key (generated by JS): <span id="bobPrivate"></span></p>
<p>Alice Public Key (A = g^a mod p): <span id="alicePublic"></span></p>
<p>Bob Public Key (B = g^b mod p): <span id="bobPublic"></span></p>
<p>Alice Shared Secret Key: <span id="aliceSecret"></span></p>
<p>Bob Shared Secret Key: <span id="bobSecret"></span></p>
</body>
</html>
