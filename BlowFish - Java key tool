import javax.crypto.Cipher;
import javax.crypto.KeyGenerator;
import javax.crypto.SecretKey;
import java.util.Scanner;

public class BlowfishJava5 {

    public static void main(String[] args) throws Exception {

        Scanner sc = new Scanner(System.in);

        // Step 1: Generate Blowfish Key (128-bit)
        KeyGenerator keyGen = KeyGenerator.getInstance("Blowfish");
        keyGen.init(128);
        SecretKey secretKey = keyGen.generateKey();

        // Step 2: Accept any input string
        System.out.print("Enter any message: ");
        String plainText = sc.nextLine();

        // Step 3: Create Cipher object
        Cipher cipher = Cipher.getInstance("Blowfish");

        // Step 4: Encrypt
        cipher.init(Cipher.ENCRYPT_MODE, secretKey);
        byte[] encryptedBytes = cipher.doFinal(plainText.getBytes());

        // Print encrypted text in HEX format
        System.out.print("\nEncrypted Text (Hex): ");
        for (int i = 0; i < encryptedBytes.length; i++) {
            String hex = Integer.toHexString(0xFF & encryptedBytes[i]);
            if (hex.length() == 1) {
                System.out.print("0");
            }
            System.out.print(hex);
        }
        System.out.println();

        // Step 5: Decrypt
        cipher.init(Cipher.DECRYPT_MODE, secretKey);
        byte[] decryptedBytes = cipher.doFinal(encryptedBytes);

        String decryptedText = new String(decryptedBytes);
        System.out.println("Decrypted Text: " + decryptedText);

        sc.close();
    }
}
